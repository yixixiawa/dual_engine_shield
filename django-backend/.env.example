# ======================== Django 设置 ========================
DEBUG=True
DJANGO_SETTINGS_MODULE=dual_shield_backend.settings

# 生产环境需要改成强随机密钥，不要使用默认值
SECRET_KEY=django-insecure-dev-key-change-in-production-environment

# 允许的主机列表（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# ======================== CORS 配置 ========================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ======================== 数据库配置 ========================
# SQLite（默认开发环境）
# 无需配置，使用 db.sqlite3

# PostgreSQL（生产环境推荐）
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=dual_shield
# DB_USER=postgres
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432

# MySQL
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=dual_shield
# DB_USER=root
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=3306

# ======================== 模型路径配置 ========================
# 钓鱼检测模型路径
PHISHING_MODEL_DIR=./models/phishing

# 漏洞检测模型路径
VULN_MODEL_DIR=./models/VR

# HuggingFace 模型缓存目录
TRANSFORMERS_CACHE=./models/hub

# ======================== GPU 配置 ========================
# CUDA 可见设备 (多个GPU用逗号分隔，例如 0,1,2)
CUDA_VISIBLE_DEVICES=0

# 计算设备选择（cuda/cpu/auto）
DETECTION_DEVICE=auto

# ======================== 日志配置 ========================
LOG_LEVEL=INFO
LOG_DIR=./logs

# ======================== 任务队列配置 (可选) ========================
# Redis 连接 (用于 Celery/缓存)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ======================== 安全配置 ========================
# HTTPS/SSL 重定向（生产环境设为 True）
SECURE_SSL_REDIRECT=False

# 安全 Cookie 设置
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS 设置（生产环境推荐开启）
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ======================== 检测配置 ========================
# 钓鱼检测默认阈值
PHISHING_THRESHOLD=0.7

# 漏洞检测默认语言
VULN_LANGUAGES=python,c,cpp,java,javascript

# ======================== 文件上传配置 ========================
# 最大上传文件大小（字节）
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880

# 最大内存上传大小（字节）
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880

# ======================== 时区设置 ========================
TIME_ZONE=Asia/Shanghai

